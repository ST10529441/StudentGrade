<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:id="@+id/main"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    tools:context=".MainActivity">

    <TextView
        android:id="@+id/textView"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="Students Marks Grade App"
        android:textSize="20sp"
        android:textStyle="bold"
        tools:layout_editor_absoluteX="84dp"
        tools:layout_editor_absoluteY="42dp" />

    <EditText
        android:id="@+id/txtName"
        android:layout_width="356dp"
        android:layout_height="51dp"
        android:ems="10"
        android:hint="Name"
        android:inputType="text"
        tools:layout_editor_absoluteX="31dp"
        tools:layout_editor_absoluteY="173dp" />

    <EditText
        android:id="@+id/txtAge"
        android:layout_width="355dp"
        android:layout_height="48dp"
        android:ems="10"
        android:hint="Age"
        android:inputType="number"
        tools:layout_editor_absoluteX="31dp"
        tools:layout_editor_absoluteY="231dp" />

    <EditText
        android:id="@+id/txtSubject"
        android:layout_width="356dp"
        android:layout_height="46dp"
        android:ems="10"
        android:hint="Student"
        android:inputType="text"
        tools:layout_editor_absoluteX="31dp"
        tools:layout_editor_absoluteY="288dp" />

    <EditText
        android:id="@+id/txtMark"
        android:layout_width="357dp"
        android:layout_height="53dp"
        android:ems="10"
        android:hint="Mark obtained (0-100)"
        android:inputType="number"
        tools:layout_editor_absoluteX="31dp"
        tools:layout_editor_absoluteY="342dp" />

    <Button
        android:id="@+id/btnEvaluate"
        android:layout_width="218dp"
        android:layout_height="60dp"
        android:text="Compute Grade"
        tools:layout_editor_absoluteX="31dp"
        tools:layout_editor_absoluteY="414dp" />

    <TextView
        android:id="@+id/txtResult"
        android:layout_width="311dp"
        android:layout_height="187dp"
        android:text="Result will appear here"
        tools:layout_editor_absoluteX="48dp"
        tools:layout_editor_absoluteY="501dp" />

    <EditText
        android:id="@+id/txtStudentNo"
        android:layout_width="358dp"
        android:layout_height="53dp"
        android:ems="10"
        android:hint="Student No."
        android:inputType="text"
        tools:layout_editor_absoluteX="31dp"
        tools:layout_editor_absoluteY="114dp" />

    <Button
        android:id="@+id/btnClear"
        android:layout_width="114dp"
        android:layout_height="62dp"
        android:text="Clear"
        tools:layout_editor_absoluteX="272dp"
        tools:layout_editor_absoluteY="414dp" />

</androidx.constraintlayout.widget.ConstraintLayout>